# Copy to ".env", fill values, restart "npm run dev". Do not commit .env.
# Backend repo & API notes: https://github.com/project-favo/backend (see FRONTEND_API_DOCUMENTATION.md)

# Backend base URL (no trailing slash).
# - Local + Spring on 8080: leave EMPTY — browser calls /api on Vite; proxy → VITE_DEV_PROXY_TARGET
# - Or set full URL for direct browser requests (CORS must allow your dev origin)
# - Deployed (örnek): https://backend-production-f771.up.railway.app
VITE_API_BASE_URL=

# Vite dev proxy for /api when VITE_API_BASE_URL is empty. Default if unset: http://127.0.0.1:8080
# Yerel Spring yoksa örnek: https://backend-production-f771.up.railway.app
# VITE_DEV_PROXY_TARGET=

# Firebase — same project as backend (Console → Project settings → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
